{% set platform_names = ctx.platforms | map(attribute='name') | list %}
build {
  sources = [
{%- for arch in ctx.archs %}
{%- if 'qemu' in platform_names %}
    "source.qemu.alpine_{{ arch }}",
{%- endif %}
{%- if 'hcloud' in platform_names %}
    "source.hcloud.alpine_{{ arch }}",
{%- endif %}
{%- endfor %}
  ]

{%- for arch in ctx.archs %}
{%- if 'hcloud' in platform_names %}
  provisioner "shell" {
    only = ["hcloud.alpine_{{ arch }}"]
    environment_vars = ["FETCH_URL={{ ctx.resolve_url('rootfs', arch) }}"]
    expect_disconnect = true
    script = "hcloud_kickstart.sh"
  }
{%- endif %}
{%- endfor %}

  provisioner "ansible" {
    ansible_env_vars = ["HOST_KEY_CHECKING=false"]
    extra_arguments = [
      "--extra-vars",
      jsonencode({
        apk_repos = [for repo in ["main", "community"] : "{{ ctx.resolve_url('base', ctx.archs[0]) }}/${repo}"]
        root_ssh_keypair_public = "${local.root_ssh_keypair.public}"
      })
    ]
    playbook_file = "ansible-playbook.yml"
    user = "root"
    use_proxy = false
  }

{%- for arch in ctx.archs %}
{%- if 'qemu' in platform_names %}
  post-processor "checksum" {
    only = ["qemu.alpine_{{ arch }}"]
    checksum_types = ["sha256"]
    output = "dist/alpine-image_{{ arch }}/alpine_{{ arch }}.qcow2.{{ '{{' }}.ChecksumType{{ '}}' }}"
  }
{%- endif %}
{%- endfor %}
}
